VITE_API_URL=http://localhost:8000

# EmailJS — contact form notification. Sign up at https://www.emailjs.com,
# create a service + template, then paste the three IDs here. With all
# three set, the /contact form fires an email to your inbox in addition
# to writing the waitlist row. If any is missing, the email step is
# skipped silently and the BE write still happens.
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
